GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
VITE_API_BASE_URL=http://127.0.0.1:8082/api
APP_CORS_ALLOWED_ORIGIN=http://127.0.0.1:5180,http://localhost:5180

# Local dev: point the backend at the bundled postgres container.
# If left unset, docker-compose falls back to the production RDS defaults.
DATABASE_URL=jdbc:postgresql://postgres:5432/gradflow
DATABASE_USERNAME=gradflow
DATABASE_PASSWORD=gradflow
